generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── MULTI-TENANCY ───

model Organization {
  id                   String   @id @default(uuid())
  name                 String
  logo                 String?
  defaultLanguage      String   @default("en")
  timezone             String   @default("UTC")
  chatVisibilityAll    Boolean  @default(true)
  status               String   @default("active") // active | suspended
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users                User[]
  chats                Chat[]
  broadcasts           Broadcast[]
  templates            Template[]
  tags                 Tag[]
  languages            Language[]
  integrations         Integration[]
  messengerConfigs     OrgMessengerConfig[]
  antibanSettings      AntibanSettings[]
  activityLogs         ActivityLog[]
  globalBroadcastLimits Json?   // max values admin can't exceed
  pendingImports       Json?    // per-messenger count of discovered-but-not-imported chats: { [messenger]: { count, at } }
  wikiCategories       WikiCategory[]
  wikiArticles         WikiArticle[]
  wikiTags             WikiTag[]
}

// ─── USERS ───

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String
  passwordHash     String
  avatar           String?
  role             String   @default("user") // superadmin | admin | user
  status           String   @default("active") // active | deactivated
  // Per-user permission toggles, managed by the org admin. Enforced in the API
  // (not just hidden in UI). Defaults preserve pre-v2.2 behavior for existing users.
  canCreateTags            Boolean @default(true)
  canSelfConnectMessengers Boolean @default(false)
  canViewAllChats          Boolean @default(true)
  lastActiveAt     DateTime?
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  deletedAt        DateTime?

  ownedChats       Chat[]   @relation("ChatOwner")
  importedChats    Chat[]   @relation("ChatImporter")
  chatOwnerLinks   ChatOwner[] @relation("ChatOwnerLinks")
  broadcasts       Broadcast[]
  templates        Template[]
  refreshTokens    RefreshToken[]
  chatPreferences  ChatPreference[]
  passwordResetTokens PasswordResetToken[]
  wikiArticles     WikiArticle[]  @relation("WikiArticleAuthor")
  wikiArticlesUpdated WikiArticle[] @relation("WikiArticleUpdater")

  @@index([organizationId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@index([userId]) // bulk revocation on suspend/deactivate/password change
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// ─── CHATS ───

model Chat {
  id               String   @id @default(uuid())
  name             String
  messenger        String   // telegram | slack | whatsapp | gmail
  externalChatId   String   // ID in the messenger's system
  chatType         String   @default("direct") // direct | group | channel
  status           String   @default("active") // active | read-only
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  ownerId          String?
  owner            User?    @relation("ChatOwner", fields: [ownerId], references: [id])
  ownerName        String?  // free-text owner label (replaces user-based owner)
  importedById     String
  importedBy       User     @relation("ChatImporter", fields: [importedById], references: [id])
  messageCount     Int      @default(0)
  lastActivityAt   DateTime?
  syncStatus       String   @default("pending") // pending | syncing | synced | failed
  syncCursor       String?  // adapter-specific pagination cursor for resumable sync
  hasFullHistory   Boolean  @default(false) // true once full message history has been pulled
  missedScans      Int      @default(0) // consecutive reachability checks that missed this chat
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  messages         Message[]
  tags             ChatTag[]
  languages        ChatLanguage[]
  preferences      ChatPreference[]
  broadcastChats   BroadcastChat[]
  participants     ChatParticipant[]
  owners           ChatOwner[]

  @@unique([externalChatId, messenger, organizationId])
  @@index([organizationId])
  @@index([organizationId, lastActivityAt])
  @@index([organizationId, messenger, deletedAt]) // discovery/import diffing
  @@index([organizationId, status]) // reachability filters + refresh-statuses
  @@index([ownerId])
  @@index([importedById])
}

// Many-to-many chat ownership. A chat is one row per org (deduped on
// externalChatId+messenger); every user whose connected account can reach it
// gets a link here. Disconnecting one owner's integration removes only their
// links — the chat survives for the remaining owners.
model ChatOwner {
  id            String   @id @default(uuid())
  chatId        String
  chat          Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation("ChatOwnerLinks", fields: [userId], references: [id])
  integrationId String?  // connection that produced this link; NULL for legacy backfill / manual assignment
  createdAt     DateTime @default(now())

  @@unique([chatId, userId])
  @@index([userId])
  @@index([integrationId])
}

model ChatTag {
  chatId  String
  tagId   String
  chat    Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  tag     Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([chatId, tagId])
  @@index([tagId])
}

// Per-chat language labels (Item 3). Structurally identical to Tag/ChatTag —
// a chat can carry MULTIPLE languages. color is optional (languages render as
// neutral chips when unset).
model Language {
  id             String   @id @default(uuid())
  name           String
  color          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  chats          ChatLanguage[]

  @@unique([name, organizationId])
}

model ChatLanguage {
  chatId     String
  languageId String
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@id([chatId, languageId])
  @@index([languageId])
}

model ChatPreference {
  id       String  @id @default(uuid())
  userId   String
  chatId   String
  pinned   Boolean @default(false)
  favorite Boolean @default(false)
  muted    Boolean @default(false)
  unread   Boolean @default(false) // manual unread mark
  user     User    @relation(fields: [userId], references: [id])
  chat     Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([userId, chatId])
}

model ChatParticipant {
  id             String @id @default(uuid())
  chatId         String
  chat           Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  externalUserId String
  displayName    String
  role           String? // admin | member

  @@unique([chatId, externalUserId])
  @@index([chatId])
}

// ─── DISCOVERED CHATS ───
// Chats a scan has seen that were never imported. Kept in sync on every scan:
// rows appear when first discovered (firstSeenAt is stable across scans) and
// disappear once the chat is imported or vanishes from the messenger.

model DiscoveredChat {
  id             String   @id @default(uuid())
  organizationId String
  messenger      String
  externalChatId String
  name           String?
  chatType       String?  // direct | group | channel | unknown; carried into Chat.chatType on import
  firstSeenAt    DateTime @default(now())

  @@unique([organizationId, messenger, externalChatId])
  @@index([organizationId, messenger])
}

// ─── MESSAGES ───

model Message {
  id               String   @id @default(uuid())
  chatId           String
  chat             Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  externalMessageId String?
  senderName       String
  senderExternalId String?
  fromEmail        String?  // Gmail sender address — used for chat grouping by domain
  isSelf           Boolean  @default(false)
  text             String
  editedAt         DateTime?
  replyToMessageId String?  // internal message ID
  replyToMessage   Message? @relation("MessageReply", fields: [replyToMessageId], references: [id])
  replies          Message[] @relation("MessageReply")
  isPinned         Boolean  @default(false)
  deliveryStatus   String?  // sent | delivered | read | failed
  attachmentsLegacy Json?   @map("attachments") // legacy JSON field, use attachmentFiles relation instead
  deletedAt        DateTime?
  createdAt        DateTime @default(now())

  // Email rendering fields (Gmail). NULL for other messengers.
  subject          String?
  htmlBody         String?  @db.Text
  plainBody        String?  @db.Text
  toEmails         String[] @default([])
  ccEmails         String[] @default([])
  bccEmails        String[] @default([])
  inReplyTo        String?  // RFC Message-ID header for threading

  attachmentFiles  Attachment[]
  reactions        Reaction[]

  @@unique([chatId, externalMessageId])
  @@index([chatId, createdAt])
  @@index([externalMessageId])
}

// ─── REACTIONS ───

model Reaction {
  id              String   @id @default(uuid())
  messageId       String
  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId          String
  emoji           String   // Unicode emoji character
  externalSynced  Boolean  @default(false)
  externalUserId  String?
  createdAt       DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@unique([messageId, externalUserId, emoji])
  @@index([messageId])
  @@index([userId])
}

// ─── BROADCASTS ───

model Broadcast {
  id               String   @id @default(uuid())
  name             String
  messageText      String
  attachments      Json?
  status           String   @default("draft") // draft | scheduled | sending | sent | partially_failed | failed
  scheduledAt      DateTime?
  sentAt           DateTime?
  deliveryRate     Float?
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdById      String
  createdBy        User     @relation(fields: [createdById], references: [id])
  templateId       String?
  // Per-messenger sending account: { [messenger]: { integrationId, sendAs?: 'bot'|'user' } }.
  // NULL = legacy behavior (org's first connected integration per messenger).
  senderConfig     Json?
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  chats            BroadcastChat[]

  @@index([organizationId])
  @@index([organizationId, status]) // list tabs + stuck-broadcast recovery
}

model BroadcastChat {
  id            String  @id @default(uuid())
  broadcastId   String
  broadcast     Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  chatId        String
  chat          Chat    @relation(fields: [chatId], references: [id])
  status        String  @default("pending") // pending | sent | failed | retrying | retry_exhausted
  errorReason   String?
  retryCount    Int     @default(0)
  sentAt        DateTime?
  updatedAt     DateTime @default(now()) @updatedAt // when the status last changed — timestamps the delivery log

  @@unique([broadcastId, chatId])
  @@index([status])
  @@index([broadcastId, status])
}

// ─── TEMPLATES ───

model Template {
  id             String   @id @default(uuid())
  name           String
  messageText    String
  attachments    Json?    // optional files attached to the template, carried into broadcasts
  usageCount     Int      @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id])
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

// ─── TAGS ───

model Tag {
  id             String   @id @default(uuid())
  name           String
  color          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  chats          ChatTag[]

  @@unique([name, organizationId])
}

// ─── INTEGRATIONS ───

model Integration {
  id             String   @id @default(uuid())
  messenger      String   // telegram | slack | whatsapp | gmail
  status         String   @default("disconnected") // connected | disconnected | token_expired | session_expired
  credentials    Json     // encrypted: tokens, session data, etc.
  settings       Json?    // per-integration settings (e.g. Slack channels)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String   // which user connected this integration
  scope          String   @default("org") // org (shared org-level connection) | user (personal account)
  connectedAt    DateTime?

  // Initial sync progress (set when integration is first connected and all chats
  // are being pulled). syncStatus values: idle | syncing | synced | failed.
  syncStatus         String    @default("idle")
  syncTotalChats     Int?
  syncCompletedChats Int?
  syncStartedAt      DateTime?
  syncError          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([messenger, organizationId, userId, scope])
  @@index([organizationId])
}

// ─── PLATFORM CONFIG ───

model PlatformConfig {
  id          String   @id @default(uuid())
  messenger   String   @unique // telegram | slack | gmail | whatsapp
  credentials Json     // encrypted via AES-256-GCM
  enabled     Boolean  @default(true)
  updatedBy   String?  // userId of last superadmin who modified
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Per-organization messenger app credentials (Telegram apiId/apiHash, Slack
// clientId/secret, ...), managed by the org admin. Runtime resolution prefers
// this over the global PlatformConfig; existing orgs are backfilled from the
// global config so nothing breaks at cutover.
model OrgMessengerConfig {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  messenger      String
  credentials    Json     // encrypted via AES-256-GCM (same lib/crypto.ts as PlatformConfig)
  enabled        Boolean  @default(true)
  updatedBy      String?  // userId of last admin who modified
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, messenger])
}

// ─── ANTIBAN ───

model AntibanSettings {
  id                    String @id @default(uuid())
  messenger             String // telegram | slack | whatsapp | gmail
  messagesPerBatch      Int
  delayBetweenMessages  Int    // seconds
  delayBetweenBatches   Int    // seconds
  maxMessagesPerHour    Int
  maxMessagesPerDay     Int
  autoRetryEnabled      Boolean @default(true)
  maxRetryAttempts      Int     @default(3)
  retryWindowHours      Int     @default(6)
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id])

  @@unique([messenger, organizationId])
}

// ─── ACTIVITY LOG ───

model ActivityLog {
  id             String   @id @default(uuid())
  category       String   // chats | messages | broadcast | templates | users | integrations | settings | organizations
  action         String   // e.g. "chat_imported", "broadcast_sent"
  description    String
  targetType     String?  // chat | broadcast | template | user | integration | organization
  targetId       String?
  userId         String?
  userName       String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, userId, createdAt])
  @@index([category])
}

// ─── INCOMING WEBHOOKS ───

model IncomingWebhook {
  id             String    @id @default(uuid())
  source         String    // telegram | slack | whatsapp | gmail
  payload        Json
  processedAt    DateTime?
  error          String?
  createdAt      DateTime  @default(now())

  @@index([source, createdAt])
}

// ─── ATTACHMENTS ───

model Attachment {
  id           String   @id @default(uuid())
  messageId    String
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url          String
  filename     String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  @@index([messageId])
}

// ─── WIKI ───

enum WikiArticleType {
  article
  case_study  // "case" is reserved in some contexts, using case_study
}

enum WikiArticleStatus {
  draft
  published
}

model WikiCategory {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  slug           String
  description    String?
  icon           String?  // emoji
  parentId       String?
  parent         WikiCategory? @relation("CategoryTree", fields: [parentId], references: [id])
  children       WikiCategory[] @relation("CategoryTree")
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  articles       WikiArticle[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([parentId])
}

model WikiArticle {
  id             String            @id @default(uuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  categoryId     String
  category       WikiCategory      @relation(fields: [categoryId], references: [id])
  authorId       String
  author         User              @relation("WikiArticleAuthor", fields: [authorId], references: [id])
  updatedById    String?
  updatedBy      User?             @relation("WikiArticleUpdater", fields: [updatedById], references: [id])
  title          String
  slug           String
  content        Json              // ProseMirror JSON from TipTap
  type           WikiArticleType   @default(article)
  status         WikiArticleStatus @default(draft)
  caseProblem    String?           // short problem description for case_study
  caseSolution   String?           // short solution description for case_study
  viewCount      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  tags           WikiArticleTag[]

  @@unique([slug, organizationId])
  @@index([organizationId, categoryId, createdAt])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([authorId])
}

model WikiTag {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  color          String   @default("#6366f1")
  createdAt      DateTime @default(now())

  articles       WikiArticleTag[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model WikiArticleTag {
  articleId String
  article   WikiArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       WikiTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
}
